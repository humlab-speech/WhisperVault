# Containerfile for whisperx offline transcription
# Build with: podman build -t whisperx-local -f container/Containerfile .

FROM python:3.12-slim

# system dependencies required by whisperx
RUN apt-get update && \
    apt-get install -y --no-install-recommends git ffmpeg && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# copy entire repository first so pip install can see the package code
COPY . /app

# install whisperx (lives in the whisperx/ subdirectory) and API-server deps
RUN pip install --no-cache-dir ./whisperx fastapi 'uvicorn[standard]' python-multipart

# download NLTK data needed for alignment so the container can run offline
RUN python -c "import nltk; nltk.download('punkt', download_dir='/usr/local/nltk_data'); nltk.download('punkt_tab', download_dir='/usr/local/nltk_data')"

# ensure scripts are executable
RUN chmod +x /app/container/server.py /app/container/manage.py

# server.py is the container entrypoint (listens on a Unix Domain Socket).
# manage.py is the HOST-SIDE management script; it is also present inside
# the image but is not invoked by default.
#
# Modes (controlled by the first argument after the image name):
#   (no arg) / "server"        → persistent UDS API server  [default]
#   "standalone" <audio> ...   → one-shot CLI passthrough, then exits
ENTRYPOINT ["/app/container/server.py"]
CMD ["server"]
